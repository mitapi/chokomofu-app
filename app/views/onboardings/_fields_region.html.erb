<section class="mt-[60px] space-y-3">
  <div class="font-medium flex items-center justify-between relative">
    <h2 class="underline underline-offset-4 decoration-2 decoration-amber-400 text-[#5b2d00]">
      お天気の地域を選ぼう
    </h2>
    <%= render "shared/field_error", object: f.object, attribute: :region %>
  </div>

  <div class="text-sm leading-relaxed text-[#5b2d00]/70 text-left w-full">
    <ul class="list-disc list-inside space-y-1">
      <li>会話や背景に使われる天気が変わるよ</li>
      <li>登録後に変更することもできるよ（準備中）</li>
    </ul>
  </div>

  <div class="flex flex-wrap gap-3 pt-2 text-[#5b2d00] w-full">
    <% regions = [
      ["東京", :tokyo],
      ["大阪", :osaka],
      ["福岡", :fukuoka],
      ["札幌", :sapporo]
    ] %>

    <!-- エラーメッセージが出るとボタンが押せない状況を解決するため、以下のファイルを追加 -->
    <!-- config/initializers/field_error_proc.rb -->

    <% regions.each do |label, key| %>
      <label class="cursor-pointer">
        <%= f.radio_button :region, key, class: "peer sr-only" %>
        <span class="
          inline-flex min-w-[72px] justify-center rounded-xl border px-4 py-2 text-center font-bold text-[#5b2d00]
          bg-white hover:bg-amber-200
          peer-checked:bg-amber-200
          transition
        ">
          <%= label %>
        </span>
      </label>
    <% end %>
  </div>
</section>