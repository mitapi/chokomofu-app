<%= form_with model: @user, url: onboarding_path, method: :patch do |f| %>
  <div class="space-y-8">
    <%= render "onboardings/fields_nickname", f: f %>

    <%= render "onboardings/fields_region", f: f %>

    <%= render "onboardings/fields_terms", f: f %>

    <section class="flex justify-center mt-10 mb-10">
      <%= f.submit "登録する",
            class: "font-bold flex h-10 items-center justify-center rounded-md bg-amber-400 px-4 py-2 text-white hover:bg-orange-400" %>
    </section>
  </div>
<% end %>