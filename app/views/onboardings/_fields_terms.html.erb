<section class="mt-[60px] space-y-3">
  <div class="font-medium flex items-center justify-between">
    <h2 class="underline underline-offset-4 decoration-2 decoration-amber-400 text-[#5b2d00]">
      利用規約（抜粋）
    </h2>
    <%= render "shared/field_error", object: f.object, attribute: :terms %>
  </div>

  <div
    role="region"
    aria-label="利用規約の抜粋"
    tabindex="0"
    class="h-[130px] w-full overflow-y-auto rounded-xl border border-amber-200 bg-white/90 p-4 text-sm text-[#5b2d00]"
  >
    <%= render "static/terms_body" %>
  </div>

  <p class="text-xs text-[#5b2d00]">
    くわしくは <%= link_to "利用規約全文", terms_path, class: "underline text-amber-700" %> をご確認ください。
  </p>

  <!-- 規約チェック（未同意のときだけ表示） -->
  <% if @user.terms_agreed_at.present? %>
    <p class="mt-3 text-xs text-gray-500">
      規約同意済み（<%= @user.terms_agreed_at.strftime("%Y/%m/%d") %>）
    </p>
  <% else %>
    <div class="pt-2">
      <label class="flex items-start gap-3 text-[#5b2d00] cursor-pointer">
        <%= f.check_box :terms, { class: "mt-0.5 scale-125" }, "1", "0" %>
        <span class="text-sm leading-relaxed font-bold">
          利用規約に同意します
        </span>
      </label>
    </div>
  <% end %>
</section>