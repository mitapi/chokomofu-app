<section class="font-medium flex items-center justify-between mt-[30px] mb-[0px] relative">
  <%= f.label :nickname, "ニックネーム",
        class: "underline underline-offset-4 decoration-2 decoration-amber-400 text-[#5b2d00]" %>
  <%= render "shared/field_error", object: @user, attribute: :nickname %>
</section>

<section class="mt-3 space-y-3">
  <div class="text-sm leading-relaxed text-[#5b2d00]/70 text-left w-full">
    <ul class="list-disc list-inside space-y-1">
      <li>10文字以内で入力してね</li>
      <li>使用できる文字：ひらがな／カタカナ／漢字／英数字／スペース</li>
      <li>登録後に変更することもできるよ（準備中）</li>
    </ul>
  </div>

  <%= f.text_field :nickname,
        class: "w-full rounded border border-gray-300 bg-white p-2 text-[17px] font-medium text-[#5b2d00] outline-none focus:ring focus:ring-yellow-200",
        maxlength: 10,
        autofocus: true,
        placeholder: "例：もふLOVE人間" %>
</section>