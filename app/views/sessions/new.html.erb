<div class="min-h-screen bg-slate-50">
  <section class="bg-[#ffebb8] shadow-sm border-b border-yellow-300/40 flex items-center justify-center relative h-[75px] text-[30px] font-bold text-[#5b2d00]">
    アカウント引継ぎ
  </section>

  <section class="px-6 py-10 md:px-12">
    <div class="mx-auto w-full max-w-[450px]">
      <p class="text-[#7a4b22] leading-8">
        引き継ぎ設定で登録したメールアドレスとパスワードでログインすると、
        これまでのぽめまるとの思い出を続けられます。
      </p>

      <% if flash.now[:alert] %>
        <div class="mt-6 rounded-lg bg-red-100 px-4 py-3 text-red-700">
          <%= flash.now[:alert] %>
        </div>
      <% end %>

      <%= form_with url: login_path,
            method: :post,
            data: { turbo: false },
            html: { novalidate: true, class: "mt-8 space-y-8" } do %>

        <div>
          <p class="font-bold text-[#7a4b22]">メールアドレス</p>
          <%= email_field_tag :email, params[:email],
              required: true,
              class: "mt-3 w-full rounded border border-gray-300 bg-white p-2 text-[17px] font-medium text-[#5b2d00] outline-none focus:ring focus:ring-yellow-200" %>
        </div>

        <div>
          <p class="font-bold text-[#7a4b22]">パスワード</p>
          <%= password_field_tag :password, nil,
              required: true,
              class: "mt-3 w-full rounded border border-gray-300 bg-white p-2 text-[17px] font-medium text-[#5b2d00] outline-none focus:ring focus:ring-yellow-200" %>
        </div>

        <div class="pt-4 text-center">
          <%= submit_tag "ログイン",
              class: "rounded-md bg-amber-400 px-6 py-2 font-bold text-white hover:bg-orange-400" %>
        </div>

      <% end %>
    </div>
  </section>
</div>