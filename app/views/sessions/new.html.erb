<div class="bg-slate-50 min-h-screen flex flex-col w-[600px]">
  <section class="bg-[#ffebb8] shadow-sm border-b border-yellow-300/40 flex font-bold justify-center items-center relative text-[30px] text-[#5b2d00] h-[75px] w-auto">
    <%= "アカウント引継ぎ" %>
  </section>

  <section class="flex flex-col justify-center items-center px-12 relative">
    <p class="pt-10 text-[#7a4b22] leading-8">
      引き継ぎ設定で登録したメールアドレスとパスワードでログインすると、
      これまでのぽめまるとの思い出を続けられます。
    </p>

    <div class="mt-[40px]">
      <% if flash.now[:alert] %>
        <div class="rounded-lg bg-red-100 px-4 py-3 text-red-700">
          <%= flash.now[:alert] %>
        </div>
      <% end %>

      <%= form_with url: login_path, method: :post, data: { turbo: false } do %>

        <div>
          <p class="font-bold text-[#7a4b22]">メールアドレス</p>
          <%= email_field_tag :email, params[:email],
              required: true,
              class: "font-medium text-[17px] text-[#5b2d00] mt-[10px] w-[450px]
                      rounded border border-gray-300 bg-white p-2 outline-none focus:ring focus:ring-yellow-200" %>
        </div>

        <div class="mt-[30px]">
          <p class="font-bold text-[#7a4b22]">パスワード</p>
          <%= password_field_tag :password, nil,
              required: true,
              class: "font-medium text-[17px] text-[#5b2d00] mt-[10px] w-[450px]
                      rounded border border-gray-300 bg-white p-2 outline-none focus:ring focus:ring-yellow-200" %>
        </div>

        <div class="text-center mt-12">
          <%= submit_tag "ログイン",
              class: "font-bold rounded-md bg-amber-400 px-4 py-2 text-white hover:bg-orange-400" %>
        </div>

      <% end %>
    </div>
  </section>
</div>