<div class="bg-slate-50 min-h-screen w-full flex flex-col overflow-x-hidden">
  <section class="bg-[#ffebb8] shadow-sm border-b border-yellow-300/40 flex items-center relative h-[75px] w-full">
    <div class="flex w-full items-center px-4">
      <div class="w-[44px] flex items-center justify-start">
        <%= link_to mypage_path,
            class: "flex items-center justify-center rounded-full bg-[#fffbf5] hover:bg-[#f5efe6] p-1 shadow-sm" do %>
          <%= render "shared/icon_close", class: "w-7 h-7" %>
        <% end %>
      </div>

      <div class="flex-1 text-center">
        <h1 class="text-[30px] font-bold text-[#5b2d00]">
          引き継ぎ設定
        </h1>
      </div>

      <div class="w-[44px]"></div>
    </div>
  </section>

  <div class="w-full px-4 pt-10 text-[#5b2d00]">
    <div class="mx-auto w-full max-w-[450px]">
      <% if @account_page == "done" %>
        <%= render "done_account" %>
      <% else %>
        <%= render "account_form" %>
      <% end %>
    </div>
  </div>
</div>