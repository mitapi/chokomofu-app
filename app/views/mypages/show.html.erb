<div class="w-full min-h-screen overflow-x-hidden">
  <section class="bg-[#ffebb8] shadow-sm border-b border-yellow-300/40 flex items-center relative h-[75px] w-full">
    <div class="flex w-full items-center px-4">
      <div class="w-[44px] flex items-center justify-start">
        <%= link_to "/main",
            class: "flex items-center justify-center rounded-full bg-[#fffbf5] hover:bg-[#f5efe6] p-1 shadow-sm" do %>
          <%= render "shared/icon_close", class: "w-7 h-7" %>
        <% end %>
      </div>

      <div class="flex-1 text-center">
        <h1 class="text-[30px] font-bold text-[#5b2d00]">マイページ</h1>
      </div>

      <div class="w-[44px]"></div>
    </div>
  </section>

  <!-- 以下ボタン群 -->
  <div class="w-full px-4 pt-[30px] pb-[40px]">
    <div class="mx-auto w-full max-w-[450px] space-y-8">

      <section class="w-full mb-9">
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-5">
            <h2 class="text-sm font-semibold text-gray-600">プロフィール</h2>
            <%= render "shared/flash_notice" %>
          </div>

          <button
            disabled
            class="w-[100px] rounded-lg border border-gray-200 bg-gray-100 px-3 py-1 text-sm text-gray-400 flex justify-between">
            <span>編集</span>
            <span class="text-xs">準備中</span>
          </button>
            <!-- ⭐実装したらクリック可能にする -->
            <!-- link_to "編集", profile_mypage_path, -->
              <!-- class: "rounded-lg border border-orange-300 bg-white px-3 py-1 text-sm hover:border-orange-300 hover:bg-yellow-100" %> -->
        </div>

        <div class="flex items-center justify-start gap-4 rounded-xl border border-orange-300 bg-white p-4 w-full min-h-[140px]">
          <div class="w-30 h-24 rounded-xl bg-gray-100 flex items-center justify-center text-xs text-gray-400">
            キャラ画像
          </div>

          <div class="text-sm space-y-1">
            <p>ニックネーム：<b><%= @user.nickname %></b></p>
            <p>地域：<b><%= region_label(@user.region) %></b></p>
            <p>キャラクター：<span class="text-gray-400">—</span></p>
            <p>
              引き継ぎ設定：
              <% if current_user.auth_kind_password? %>
                <span class="text-green-600"><b>設定済み</b></span>
              <% else %>
                <span class="text-gray-400"><b>未設定</b></span>
              <% end %>
            </p>
          </div>
        </div>
      </section>

      <!-- このアプリについて -->
      <section class="w-full">
        <h2 class="text-sm font-semibold text-gray-600 mb-3">
          このアプリについて
        </h2>

        <div class="space-y-3">
          <!-- 引き継ぎ設定 -->
          <%= link_to "引き継ぎ設定",
            account_mypage_path,
            class: "block w-full rounded-lg border border-orange-300 bg-white px-4 py-3 text-left hover:border-orange-300 hover:bg-yellow-100" %>

          <!-- 遊び方 -->
          <button
            disabled
            class="w-full rounded-lg border border-gray-200 bg-gray-100 px-4 py-3 text-left text-gray-400 flex justify-between">
            <span>このゲームの遊び方</span>
            <span class="text-xs">準備中</span>
          </button>
          <!-- ⭐実装したらクリック可能にする -->
          <!-- link_to "このゲームの遊び方", "/mypage/howto", -->
            <!-- class: "block w-full rounded-lg border border-orange-300 bg-white px-4 py-3 text-left hover:border-orange-300 hover:bg-yellow-100" %> -->

          <!-- 以下は準備中 -->
          <% ["データの取り扱いについて", "利用規約", "プライバシーポリシー", "お問い合わせ"].each do |label| %>
            <button
              disabled
              class="w-full rounded-lg border border-gray-200 bg-gray-100 px-4 py-3 text-left text-gray-400 flex justify-between">
              <span><%= label %></span>
              <span class="text-xs">準備中</span>
            </button>
          <% end %>
        </div>
      </section>
    </div>
  </div>
</div>