<div class="w-full flex justify-center -translate-y-[40px]">
  <div class="relative">
    <% if snack_limited %>
      <div class="absolute left-1/2 -translate-x-1/2 -translate-y-[40px]
                  bg-[#b8945a] text-white font-bold
                  px-3 py-1 rounded-lg shadow-sm whitespace-nowrap">
        今日のおやつはおしまいだよ
      </div>
    <% end %>

    <div class="relative border border-[#bc9858] bg-[#d6bc8e] rounded-2xl shadow-lg pl-11 pr-6 pb-4 pt-3">
      <%= turbo_frame_tag "snack_detail_panel",
            class: "absolute left-0 right-0 top-0 z-50 flex justify-center" do %>
      <% end %>

      <%= link_to menu_main_path,
            data: { turbo_frame: "menu_panel" },
            class: "absolute left-[10px] top-[12px]" do %>
        <div class="rounded-full bg-[#fffbf5] hover:bg-[#f5efe6] p-1 shadow-sm">
          <%= render "shared/icon_close",
                class: "w-5 h-5 text-[#a58855]" %>
        </div>
      <% end %>

      <div class="grid grid-cols-2 gap-2">
        <% snacks.each do |snack| %>
          <%= render "snacks/card", snack: snack, snack_limited: snack_limited %>
        <% end %>
      </div>
    </div>
  </div>
</div>