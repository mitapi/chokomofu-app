<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- Zen Maru Gothic -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@300;400;500;700&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "custom", "data-turbo-track": "reload" %>
  </head>

  <body class="antialiased bg-cats font-sans min-h-screen">
    <% bgm_enabled_page = !(%w[top welcomes].include?(controller_name)) %>

    <% if bgm_enabled_page %>
      <div data-controller="bgm" class="fixed top-3 right-3 z-50">
        <audio
          data-bgm-target="audio"
          src="<%= asset_path('main.mp3') %>"
          loop
          preload="auto"></audio>

        <button
          type="button"
          data-bgm-target="button"
          data-action="bgm#toggle"
          class="rounded-full bg-amber-300/95 px-3 py-2 text-sm font-bold text-amber-900 shadow-md border border-amber-200">
          ♪ OFF
        </button>
      </div>
    <% end %>

    <% if controller_name == "top" && action_name == "index" %>
      <div class="flex min-h-screen items-center md:items-start justify-center overflow-hidden">
        <div class="w-[372px] h-[481px] md:w-[600px] md:h-auto flex items-center md:items-start justify-center">
          <div class="origin-center md:origin-top scale-[0.68] md:scale-100">
            <%= yield %>
          </div>
        </div>
      </div>

    <% elsif (controller_name == "mains" && action_name == "show") || controller_name == "chats" %>
      <div class="flex h-[100dvh] md:min-h-screen items-center md:items-start justify-center overflow-hidden md:overflow-visible">
        <div class="w-[372px] h-[560px] md:w-[600px] md:h-auto flex items-center md:items-start justify-center">
          <div class="origin-center md:origin-top scale-[0.68] md:scale-100">
            <main class="flex flex-col items-center justify-center w-[600px]">
              <%= yield %>
              <%= render("shared/footer") %>
            </main>
          </div>
        </div>
      </div>
    <% elsif controller_name == "mypages" || controller_name == "onboardings" || controller_name == "sessions"%>
      <div class="min-h-screen flex flex-col items-center">
        <main class="w-full md:max-w-[600px] flex-1 bg-slate-50 overflow-x-hidden">
          <%= yield %>
          <%= render("shared/footer") %>
        </main>
      </div>

    <% elsif controller_name == "welcomes" %>
      <div class="flex h-[100dvh] md:min-h-screen items-center md:items-start justify-center overflow-hidden md:overflow-visible bg-cats">
        <div class="w-[372px] h-[434px] md:w-[600px] md:h-auto flex items-center md:items-start justify-center">
          <div class="origin-center md:origin-top scale-[0.70] md:scale-100">
            <%= yield %>
          </div>
        </div>
      </div>

    <% else %>
      <div class="min-h-screen">
        <main class="mx-auto w-full max-w-[960px]">
          <%= yield %>
        </main>
        <%= render("shared/footer") unless controller_path == "top" && action_name == "index" %>
      </div>
    <% end %>
  </body>
</html>
