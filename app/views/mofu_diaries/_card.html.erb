<div class="relative w-full">
  <%= image_tag "diary/frame.png",
    class: "block w-full h-auto select-none pointer-events-none" %>

  <!-- タイトル -->
  <div class="absolute top-[36%] left-1/2 -translate-x-1/2 w-[78%] text-center">
    <div class="text-[13px] md:text-[18px] font-bold leading-snug whitespace-nowrap">
      <%= "#{mofu_diary.user.nickname}さんの、 #{mofu_diary.title}" %>
    </div>
  </div>

  <!-- イラスト -->
  <div class="absolute bottom-[20%] right-[7%] w-[44%] md:w-[48%]">
    <%= image_tag diary_illust_image_path(mofu_diary),
          alt: "ぽめまる",
          class: "w-full h-auto" %>
  </div>

  <!-- 本文 -->
  <div class="absolute bottom-[12%] left-1/2 -translate-x-1/2 w-[62%] text-center">
    <div class="text-[11px] md:text-[15px] leading-relaxed">
      <%= mofu_diary.line1 %><br>
      <%= mofu_diary.line2 %>
    </div>
  </div>

  <!-- 日付 -->
  <div class="absolute bottom-[12%] left-[16%] text-[10px] md:text-xs opacity-70">
    <%= mofu_diary.date %>
  </div>

  <!-- 天気 -->
  <div class="absolute bottom-[11.5%] right-[12%] opacity-70">
    <% if (p = weather_stamp_path(mofu_diary.weather_slot)) %>
      <%= image_tag p, alt: "天気", class: "w-[24px] h-[13px] md:w-[30px] md:h-[16px] drop-shadow-sm" %>
    <% end %>
  </div>
</div>